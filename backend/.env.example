# Публикация API на хосте (контейнер внутри всегда слушает 8000). Если ошибка «port 8000 already allocated»:
# HOST_API_PORT=18000  — и во frontend/.env задай VITE_DEV_API_PORT=18000
HOST_API_PORT=8000

# Локальный uvicorn (без Docker API): Postgres на localhost:5432
# Контейнер api в docker-compose сам подставляет хост db — см. backend/docker-compose.yml (environment)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/purplehack
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
TELEGRAM_BOT_TOKEN=your-bot-token
OPENAI_API_KEY=your-openai-key
ML_SERVICE_URL=http://localhost:8001
# Bot service
BACKEND_URL=http://api:8000
WEBAPP_URL=https://your-frontend-domain.com
