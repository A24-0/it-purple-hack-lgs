# Базовый URL backend API (без завершающего слэша)
VITE_API_URL=http://localhost:8000

# URL Teachable Machine модели для AR-сканера и фото-анализа
# КАК ПОЛУЧИТЬ:
# 1. Перейди на https://teachablemachine.withgoogle.com/
# 2. Create Project > Image Project
# 3. Загрузи фото: велосипед, рюкзак, телефон, дом, автомобиль
#    (каждый класс - минимум 10-15 фото, лучше 50+)
# 4. Train (обучение займёт ~30сек)
# 5. Export > TensorFlow JS > Copy the URL что начинается на https://teachablemachine.withgoogle.com/models/...
# 6. Убедись что URL заканчивается на "/" 
# Пример: https://teachablemachine.withgoogle.com/models/abcXYZ123/
VITE_TM_MODEL_URL=

